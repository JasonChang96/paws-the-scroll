{
	"name": "paws-the-scroll",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"lint": "biome check --write",
		"typecheck": "tsc --noEmit",
		"cargo:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features",
		"cargo:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
		"cargo": "pnpm run cargo:clippy && pnpm run cargo:fmt",
		"check": "pnpm run lint && pnpm run typecheck && pnpm run cargo"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-global-shortcut": "^2.3.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@tauri-apps/plugin-store": "^2.4.3",
		"clsx": "^2.1.1",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"ts-pattern": "^5.9.0",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@tauri-apps/cli": "^2.11.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.11"
	}
}
